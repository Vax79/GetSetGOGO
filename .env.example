# Obtain this server-only key from https://scrapebadger.com/dashboard/api-keys
SCRAPEBADGER_API_KEY=

# ISO 3166-1 alpha-2 TikTok content region. ScrapeBadger defaults to US.
SCRAPEBADGER_REGION=US

# Server-only Google Gemini API key for POI extraction and enrichment.
GEMINI_API_KEY=

# Gemini 3.5 Flash supports structured JSON output. Override when needed.
GEMINI_MODEL=gemini-3.5-flash

# Server-only Google Maps Platform key with Places API (New) enabled for Step 6 geocoding.
# The same key is used for Places Text Search and Place Details.
GOOGLE_PLACES_API_KEY=

# Optional dedicated Routes API key for travel-distance placement. It may be the
# same Google Maps Platform key above when that key has the Routes API enabled.
GOOGLE_ROUTES_API_KEY=
