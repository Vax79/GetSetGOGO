# Obtain this server-only key from https://scrapebadger.com/dashboard/api-keys
SCRAPEBADGER_API_KEY=

# ISO 3166-1 alpha-2 TikTok content region. ScrapeBadger defaults to US.
SCRAPEBADGER_REGION=US

# Server-only Google Gemini API key for POI extraction and enrichment.
GEMINI_API_KEY=

# Gemini 3.1 Flash-Lite supports structured JSON output. Override when needed.
GEMINI_MODEL=gemini-3.1-flash-lite

# Shared Google Maps Platform key. Enable Places API (New), Routes API, and
# Maps JavaScript API. Because Vite exposes the browser alias, restrict this
# key to only the enabled APIs and authorised frontend referrers. For production,
# prefer separate browser and server keys so each can use its proper restriction.
GOOGLE_MAPS_API_KEY=

# Backward-compatible aliases used by the backend and Vite map component.
GOOGLE_PLACES_API_KEY=${GOOGLE_MAPS_API_KEY}
GOOGLE_ROUTES_API_KEY=${GOOGLE_MAPS_API_KEY}
VITE_GOOGLE_MAPS_API_KEY=${GOOGLE_MAPS_API_KEY}

# Public URL of the separately deployed FastAPI Vercel project. Leave empty
# locally to use Vite's /api proxy. This value is embedded into the frontend.
VITE_API_BASE_URL=

# Supabase deployment configuration. Add the same values to the project-root
# .env file (this folder), never to frontend source files or a VITE_* secret.
#
# Get the database URL from Supabase Dashboard > Connect. For SQLAlchemy,
# use the psycopg driver form: postgresql+psycopg://USER:PASSWORD@HOST:PORT/DB
DATABASE_URL=

# Get these from Supabase Dashboard > Project Settings > API. The publishable
# key is intended for the browser; do not use a secret/service-role key here.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=${SUPABASE_URL}
VITE_SUPABASE_PUBLISHABLE_KEY=${SUPABASE_PUBLISHABLE_KEY}

# Comma-separated frontend origins permitted to call the deployed API.
CORS_ORIGINS=http://localhost:5173
